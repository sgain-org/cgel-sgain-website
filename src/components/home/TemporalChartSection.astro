---
import ChartBox from "@/components/ChartBox.astro";
import Section from "@/components/Section.astro";

type TemporalChartView = {
  key: string;
  label: string;
  svg: string;
};

type Props = {
  temporalChartViews: TemporalChartView[];
};

const { temporalChartViews } = Astro.props as Props;
---

<Section
  title="Temporal Evolution of Chinese-Led Initiatives Across Governance Levels and Scales"
  subtitle="China has become increasingly active in leading cross-border environmental governance, with state agencies driving this expansion. The widening spatial footprint reflects not only the diversification of China's environmental partnerships but also its growing ambition to shape global environmental agendas."
>
  <div id="chart-temporal" class="chart-switcher">
    <div class="chart-tabs">
      {
        temporalChartViews.map((view, index) => (
          <button
            type="button"
            class={`chart-tab${index === 0 ? " on" : ""}`}
            data-tab={view.key}
          >
            {view.label}
          </button>
        ))
      }
    </div>
    <ChartBox>
      <div>
        {
          temporalChartViews.map((view, index) => (
            <div
              class={`temporal-view${index === 0 ? " on" : ""}`}
              data-panel={view.key}
              set:html={view.svg}
            />
          ))
        }
      </div>
    </ChartBox>
  </div>
</Section>

<style>
  .chart-switcher {
    max-width: 880px;
    margin: 0 auto;
  }
  .chart-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: center;
    margin-bottom: 12px;
  }
  .chart-tab {
    font-family: inherit;
    font-size: 13px;
    padding: 5px 13px;
    border: 1px solid var(--line);
    background: #fff;
    border-radius: 7px;
    color: var(--muted);
    cursor: pointer;
  }
  .chart-tab:hover:not(.on) {
    border-color: var(--teal);
    color: var(--teal);
  }
  .chart-tab.on {
    background: var(--teal-d);
    border-color: var(--teal-d);
    color: #fff;
  }
  .temporal-view {
    display: none;
  }
  .temporal-view.on {
    display: block;
  }
</style>

<script>
  import { bindChartTooltips, initChartTabs } from "@/lib/homepage-client";

  initChartTabs("chart-temporal");
  bindChartTooltips();
</script>
