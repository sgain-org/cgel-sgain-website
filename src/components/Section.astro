---
interface Props {
  title: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---

<section>
  <div class="wrap">
    <div class="section-head" data-reveal>
      <h2>{title}</h2>
      {subtitle && <p>{subtitle}</p>}
    </div>
    <slot />
  </div>
</section>

<style>
  .section-head {
    margin-bottom: 22px;
  }
  .section-head h2 {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 26px;
    line-height: 1.25;
    color: var(--teal-d);
    margin-bottom: 10px;
  }
  .section-head p {
    color: var(--ink);
    font-size: 15px;
    line-height: 1.62;
  }
  @media (min-width: 601px) {
    .section-head h2,
    .section-head p {
      max-width: 90%;
    }
  }
</style>
