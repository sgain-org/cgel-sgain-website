{
  "name": "cgel-sgain-website",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "astro build",
    "check": "astro check",
    "deploy": "astro build && ./scripts/deploy.sh",
    "deploy:dry": "astro build && ./scripts/deploy.sh --dry-run",
    "dev": "astro dev",
    "lint": "biome check",
    "lint:ci": "biome ci",
    "lint:fix": "biome check --fix",
    "og:image": "node scripts/og-image.mjs",
    "preview": "astro preview",
    "svg": "svgo -rf ./public -o ./public",
    "tree": "./scripts/tree.sh",
    "unused": "knip --cache"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@lucide/astro": "^1.21.0",
    "astro": "^7.0.2",
    "d3": "^7.9.0",
    "fuse.js": "^7.4.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.5.0",
    "@types/d3": "^7.4.3",
    "knip": "^6.17.2",
    "sharp": "^0.35.2",
    "svgo": "^4.0.1",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": "24.x",
    "pnpm": "11.x"
  }
}
