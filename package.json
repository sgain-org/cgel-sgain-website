{
  "name": "cgel-sgain-website",
  "version": "1.0.0",
  "private": true,
  "description": "CGEL SGAIN Website",
  "license": "MIT",
  "author": "tomheaton",
  "type": "module",
  "scripts": {
    "build": "astro build",
    "cf:deploy": "astro build && wrangler deploy",
    "cf:preview": "astro build && wrangler dev",
    "check": "astro check",
    "deploy": "DEPLOY_TARGET=hostinger astro build && ./scripts/deploy.sh",
    "deploy:dry": "DEPLOY_TARGET=hostinger astro build && ./scripts/deploy.sh --dry-run",
    "dev": "astro dev",
    "generate-types": "wrangler types",
    "lint": "biome check",
    "lint:ci": "biome ci",
    "lint:fix": "biome check --fix",
    "og:image": "node scripts/og-image.mjs",
    "preview": "astro preview",
    "svg": "svgo -rf ./public -o ./public",
    "unused": "knip --cache"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.4",
    "@astrojs/sitemap": "^3.7.3",
    "@lucide/astro": "^1.25.0",
    "astro": "^7.1.3",
    "d3": "^7.9.0",
    "fuse.js": "^7.5.0",
    "motion": "^12.42.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.5.5",
    "@types/d3": "^7.4.3",
    "@types/node": "^26.1.1",
    "knip": "^6.27.0",
    "sharp": "^0.35.3",
    "svgo": "^4.0.2",
    "typescript": "^6.0.3",
    "wrangler": "^4.113.0"
  },
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": "26.x",
    "pnpm": "11.x"
  }
}
